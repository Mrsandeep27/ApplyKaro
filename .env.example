# Client (Vite) — used by the PWA
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_GEMINI_API_KEY=your-gemini-api-key

# Server (Node) — used by the auto-apply worker
GEMINI_API_KEY=your-gemini-api-key
PORT=3001

# Optional safety gates (unrestricted by default for personal use)
# Uncomment to enable 9am-6pm-only applying:
# APPLY_HOUR_START=9
# APPLY_HOUR_END=18
# Uncomment to skip Saturday/Sunday:
# SKIP_WEEKENDS=true

# Client (Vite) — used by the PWA
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_GEMINI_API_KEY=your-gemini-api-key

# Server (Node) — used by the auto-apply worker
GEMINI_API_KEY=your-gemini-api-key
PORT=3001

# Safety limits (can also be edited from Settings UI)
APPLY_HOUR_START=9
APPLY_HOUR_END=18
SKIP_WEEKENDS=true
